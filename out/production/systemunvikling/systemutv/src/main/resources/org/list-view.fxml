<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.ListController">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" style="-fx-background-color: #b06060; -fx-padding: 10;">
            <Label text="Name" style="-fx-text-fill: white;"/>
            <Pane HBox.hgrow="ALWAYS"/>
            <Label text="filter by"/>
            <Label text="cause"/>
            <Label text="views"/>
            <Button text="back" onAction="#goBack"/>
        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <VBox style="-fx-background-color: #d9d9d9;"/>
    </center>

</BorderPane>