<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.RegisterController">

    <!-- TOP -->
    <top>
        <HBox style="-fx-background-color: #cfcfcf; -fx-padding: 10;">
            <Pane HBox.hgrow="ALWAYS"/>
            <Button text="back" onAction="#goBack"/>
        </HBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="10" alignment="CENTER" style="-fx-padding: 30;">

            <Pane prefHeight="40" prefWidth="300" style="-fx-background-color: #a07c7c;"/>

            <Label text="Email"/>
            <TextField fx:id="emailField" prefWidth="250"/>

            <Label text="Username"/>
            <TextField fx:id="usernameField" prefWidth="250"/>

            <Label text="Password"/>
            <PasswordField fx:id="passwordField" prefWidth="250"/>

            <Label text="Confirm password"/>
            <PasswordField fx:id="confirmPasswordField" prefWidth="250"/>

            <Button text="Login" onAction="#handleRegister"
                    style="-fx-background-color: #7f8c6b; -fx-text-fill: white;"/>

        </VBox>
    </center>

</BorderPane>