<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.MainController">

    <!-- TOP NAVBAR -->
    <top>
        <HBox spacing="20" style="-fx-background-color: #cfcfcf; -fx-padding: 10;">
            <Label text="Home"/>
            <Button text="Login" onAction="#goToLogin"/>
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <HBox spacing="20" style="-fx-padding: 20;">

            <!-- LEFT PANEL -->
            <VBox prefWidth="200" style="-fx-background-color: #d9d9d9;">
                <Pane VBox.vgrow="ALWAYS"/>
                <ListView fx:id="charityListView" VBox.vgrow="ALWAYS"/>
                <Button text="Full list" onAction="#goToList"/>
            </VBox>

            <!-- MIDDLE PANEL -->
            <VBox prefWidth="200" style="-fx-background-color: #d9d9d9;" spacing="10">

                <Label text="Top 10"
                       style="-fx-background-color: #7a6b6b; -fx-text-fill: white; -fx-padding: 5;"/>

                <ListView fx:id="topListView" VBox.vgrow="ALWAYS"/>

            </VBox>

            <!-- RIGHT PANEL -->
            <VBox prefWidth="200" style="-fx-background-color: #d9d9d9;" spacing="10">

                <Label text="Random 10"
                       style="-fx-background-color: #7a6b6b; -fx-text-fill: white; -fx-padding: 5;"/>

                <ListView fx:id="randomListView" VBox.vgrow="ALWAYS"/>

            </VBox>

        </HBox>
    </center>

</BorderPane>
